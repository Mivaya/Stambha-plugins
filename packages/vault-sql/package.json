{
  "name": "@stambha/vault-sql",
  "version": "1.0.0",
  "description": "SQL drivers for Stambha Vault — SQLite and PostgreSQL backends",
  "author": "Mivaya",
  "license": "MIT",
  "homepage": "https://github.com/Mivaya/Stambha-plugins/tree/main/packages/vault-sql#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mivaya/Stambha-plugins.git",
    "directory": "packages/vault-sql"
  },
  "bugs": {
    "url": "https://github.com/Mivaya/Stambha/issues"
  },
  "keywords": [
    "discord",
    "stambha",
    "vault",
    "sqlite",
    "postgresql"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@stambha/vault": "^1.2.0"
  },
  "dependencies": {
    "pg": "^8.13.3"
  },
  "devDependencies": {
    "@stambha/vault": "^1.2.0",
    "@types/node": "^26.1.1",
    "@types/pg": "^8.11.11",
    "tsup": "^8.3.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.5.0"
  }
}
