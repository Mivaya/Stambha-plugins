{
  "name": "@stambha/api",
  "version": "1.2.0",
  "description": "HTTP API host for Stambha bots — mountable router for user-built admin frontends",
  "author": "Mivaya",
  "license": "MIT",
  "homepage": "https://github.com/Mivaya/Stambha-plugins/tree/main/packages/api#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mivaya/Stambha-plugins.git",
    "directory": "packages/api"
  },
  "bugs": {
    "url": "https://github.com/Mivaya/Stambha/issues"
  },
  "keywords": [
    "discord",
    "discord-bot",
    "stambha",
    "api",
    "dashboard",
    "http",
    "oauth"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "docs"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@stambha/core": "^1.2.1",
    "@stambha/plugins": "^1.2.1",
    "@stambha/vault": "^1.2.1"
  },
  "peerDependenciesMeta": {
    "@stambha/plugins": {
      "optional": true
    },
    "@stambha/vault": {
      "optional": true
    }
  },
  "devDependencies": {
    "@stambha/core": "^1.2.1",
    "@stambha/plugins": "^1.2.1",
    "@stambha/vault": "^1.2.1",
    "@types/node": "^26.1.1",
    "tsup": "^8.3.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=20"
  }
}
