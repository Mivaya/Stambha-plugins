{
  "name": "stambha-plugins",
  "version": "0.0.0",
  "private": true,
  "description": "Official Stambha extensions — independent npm versioning per package",
  "author": "Mivaya",
  "license": "MIT",
  "homepage": "https://github.com/Mivaya/Stambha-plugins#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mivaya/Stambha-plugins.git"
  },
  "bugs": {
    "url": "https://github.com/Mivaya/Stambha-plugins/issues"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r run typecheck",
    "version:bump": "node scripts/bump-versions.mjs",
    "publish:npm": "pnpm -r publish --access public --no-git-checks --filter './packages/*'"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.9"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
