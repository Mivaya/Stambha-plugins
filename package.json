{
  "name": "stambha-plugins",
  "version": "0.0.0",
  "private": true,
  "description": "Official Stambha extensions — independent versioning via Changesets",
  "author": "Mivaya",
  "license": "MIT",
  "homepage": "https://github.com/Mivaya/Stambha-plugins#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mivaya/Stambha-plugins.git"
  },
  "bugs": {
    "url": "https://github.com/Mivaya/Stambha-plugins/issues"
  },
  "type": "module",
  "scripts": {
    "build": "pnpm -r run build",
    "test": "pnpm -r run test",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "typecheck": "pnpm -r run typecheck",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "pnpm build && changeset publish"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@changesets/cli": "^2.29.0",
    "typescript": "^5.7.3",
    "vitest": "^3.0.5"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=20"
  }
}
