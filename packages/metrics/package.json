  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": ["dist", "README.md"],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@stambha/core": "^0.2.1"
  },
  "dependencies": {
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@stambha/core": "^0.2.1",
    "@types/node": "^25.9.3",
    "tsup": "^8.3.6",
    "typescript": "^6.0.3",
    "vitest": "^4.1.8"
  },
  "engines": {
    "node": ">=20"
  }
}
