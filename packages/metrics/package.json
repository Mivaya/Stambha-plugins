{
  "name": "@stambha/metrics",
  "version": "1.0.0",
  "description": "Prometheus metrics and observability for Stambha — counters, histograms, and /metrics HTTP server",
  "author": "Mivaya",
  "license": "MIT",
  "homepage": "https://github.com/Mivaya/Stambha-plugins/tree/main/packages/metrics#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Mivaya/Stambha-plugins.git",
    "directory": "packages/metrics"
  },
  "bugs": {
    "url": "https://github.com/Mivaya/Stambha/issues"
  },
  "keywords": [
    "discord",
    "stambha",
    "metrics",
    "prometheus",
    "observability"
  ],
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "typecheck": "tsc --noEmit",
    "test": "vitest run"
  },
  "peerDependencies": {
    "@stambha/core": "^1.2.1"
  },
  "dependencies": {
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@stambha/core": "^1.2.1",
    "@types/node": "^26.1.1",
    "tsup": "^8.3.6",
    "typescript": "^7.0.2",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=20"
  }
}
